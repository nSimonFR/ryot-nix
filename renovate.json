{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":dependencyDashboard"],
  "enabledManagers": ["custom.regex"],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Bump the upstream Ryot version pinned in flake.nix",
      "managerFilePatterns": ["/^flake\\.nix$/"],
      "matchStrings": ["version = \"(?<currentValue>[^\"]+)\";"],
      "depNameTemplate": "IgnisDa/ryot",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v?(?<version>.*)$"
    }
  ],
  "packageRules": [
    {
      "matchDepNames": ["IgnisDa/ryot"],
      "automerge": false,
      "postUpgradeTasks": {
        "commands": ["bash ci/renovate-update.sh {{{newVersion}}}"],
        "executionMode": "branch",
        "fileFilters": ["**/*"]
      }
    }
  ]
}
